<section class="section" data-screen-label="Coleção banner">
  <div class="wrap">
    <div class="coll-banner" data-reveal>
      <p class="eyebrow eyebrow--muted eyebrow--center">{{ section.settings.eyebrow }}</p>
      <h1 class="display-2 mt-4">{{ collection.title | default: section.settings.fallback_title }}</h1>
      {%- assign scene = collection.description | default: section.settings.scene_line -%}
      {%- if scene != blank -%}
        <p class="mt-5 mx-auto maxw-54" style="font-family:var(--font-body);font-style:italic;font-size:18px;color:var(--text-muted);">{{ scene | strip_html }}</p>
      {%- endif -%}
      {%- if collection != blank and collection.products_count > 0 -%}
        <p class="coll-count mt-5">{{ collection.products_count }} {% if collection.products_count == 1 %}peça nesta sala{% else %}peças nesta sala{% endif %}</p>
      {%- endif -%}
    </div>

    {%- if section.settings.show_banner -%}
      <div class="coll-hero" data-reveal>
        {%- if section.settings.banner_image != blank -%}
          <img src="{{ section.settings.banner_image | image_url: width: 2400 }}" alt="" width="{{ section.settings.banner_image.width }}" height="{{ section.settings.banner_image.height }}" loading="lazy">
        {%- elsif section.settings.banner_asset != blank -%}
          <img src="{{ section.settings.banner_asset | asset_url }}" alt="" width="928" height="1152" loading="lazy">
        {%- else -%}
          <div class="ph" style="position:absolute;inset:0;"><span>a sala · foto fora de contexto</span></div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

<section class="section section--hairline-top" data-screen-label="Coleção grade">
  <div class="wrap">
    <div class="coll-toolbar">
      <div class="coll-filters">
        <a href="{{ collection.url | default: routes.all_products_collection_url }}" class="tag {% unless current_tags %}tag--fill{% endunless %}">Tudo</a>
        {%- for tag in collection.all_tags limit: 6 -%}
          <a href="{{ collection.url }}/{{ tag | handle }}" class="tag {% if current_tags contains tag %}tag--fill{% endif %}">{{ tag }}</a>
        {%- endfor -%}
      </div>
      {%- if collection.sort_options.size > 0 -%}
        <form method="get" class="field">
          <label class="field__label" for="sort">Ordenar</label>
          <select name="sort_by" id="sort" onchange="this.form.submit()">
            {%- for opt in collection.sort_options -%}
              <option value="{{ opt.value }}" {% if opt.value == collection.sort_by or opt.value == collection.default_sort_by %}selected{% endif %}>{{ opt.name }}</option>
            {%- endfor -%}
          </select>
        </form>
      {%- endif -%}
    </div>

    {%- assign editorials = section.blocks | where: 'type', 'editorial' -%}

    {%- if collection and collection.products_count > 0 -%}
      {%- paginate collection.products by 12 -%}
        {%- if editorials.size > 0 -%}
          {%- comment -%} Bandas: 4 produtos em 2 colunas + foto editorial grande, lados alternados {%- endcomment -%}
          <div class="coll-bands">
            {%- assign band = 0 -%}
            {%- for product in collection.products -%}
              {%- assign slot = forloop.index0 | modulo: 4 -%}
              {%- if slot == 0 -%}
                {%- assign band = forloop.index0 | divided_by: 4 -%}
                {%- assign flip = band | modulo: 2 -%}
                <div class="coll-band{% if flip == 1 %} coll-band--flip{% endif %}">
                  <div class="coll-band__products">
              {%- endif -%}
              {% render 'product-card', product: product %}
              {%- if slot == 3 or forloop.last -%}
                  </div>
                  {%- assign eidx = band | modulo: editorials.size -%}
                  {%- assign e = editorials[eidx] -%}
                  <div class="coll-band__editorial" data-reveal {{ e.shopify_attributes }}>
                    {%- if e.settings.image != blank -%}
                      <img src="{{ e.settings.image | image_url: width: 1400 }}" alt="{{ e.settings.caption | escape }}" width="{{ e.settings.image.width }}" height="{{ e.settings.image.height }}" loading="lazy">
                    {%- elsif e.settings.asset != blank -%}
                      <img src="{{ e.settings.asset | asset_url }}" alt="{{ e.settings.caption | escape }}" width="928" height="1152" loading="lazy">
                    {%- else -%}
                      <div class="ph" style="position:absolute;inset:0;"><span>cena do clube</span></div>
                    {%- endif -%}
                    {%- if e.settings.caption != blank -%}
                      <span class="coll-band__label">{{ e.settings.caption }}</span>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- else -%}
          <div class="product-grid" data-reveal>
            {%- for product in collection.products -%}
              {% render 'product-card', product: product %}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if paginate.pages > 1 -%}
          <nav class="pagination" aria-label="Páginas da coleção">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}">‹ Anterior</a>
            {%- else -%}
              <span class="is-off">‹ Anterior</span>
            {%- endif -%}
            <span>{{ paginate.current_page }} / {{ paginate.pages }}</span>
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}">Próxima ›</a>
            {%- else -%}
              <span class="is-off">Próxima ›</span>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- endpaginate -%}
    {%- else -%}
      {%- comment -%} Onboarding — bandas de demonstração {%- endcomment -%}
      <div class="coll-bands">
        <div class="coll-band">
          <div class="coll-band__products">
            {% render 'product-card', ph_category: 'Bolsas', ph_name: 'A Diária', ph_price: 'R$ 590', ph_tag: 'Novo', ph_label: 'bolsa · foto de produto', ph_url: routes.all_products_collection_url %}
            {% render 'product-card', ph_category: 'Bolsas', ph_name: 'A de Duas Raquetes', ph_price: 'R$ 720', ph_label: 'bolsa · foto de produto', ph_url: routes.all_products_collection_url %}
            {% render 'product-card', ph_category: 'Bolsas', ph_name: 'A de Fim de Semana', ph_price: 'R$ 890', ph_label: 'bolsa · foto de produto', ph_url: routes.all_products_collection_url %}
            {% render 'product-card', ph_category: 'Bolsas', ph_name: 'A Compacta', ph_price: 'R$ 450', ph_label: 'bolsa · foto de produto', ph_url: routes.all_products_collection_url %}
          </div>
          <div class="coll-band__editorial">
            <img src="{{ 'photo-interlude-gravel.jpg' | asset_url }}" alt="" width="928" height="1152" loading="lazy">
            <span class="coll-band__label">Entre um jogo e outro</span>
          </div>
        </div>
        <div class="coll-band coll-band--flip">
          <div class="coll-band__products">
            {% render 'product-card', ph_category: 'Grips', ph_name: 'O Grip', ph_price: 'R$ 79', ph_tag: 'Testado', ph_label: 'grip · foto de produto', ph_url: routes.all_products_collection_url %}
            {% render 'product-card', ph_category: 'Grips', ph_name: 'O Grip · Par', ph_price: 'R$ 140', ph_label: 'grip · foto de produto', ph_url: routes.all_products_collection_url %}
          </div>
          <div class="coll-band__editorial">
            <img src="{{ 'photo-interlude-chair.jpg' | asset_url }}" alt="" width="928" height="1152" loading="lazy">
            <span class="coll-band__label">A cadeira do juiz · fim de tarde</span>
          </div>
        </div>
      </div>
      <p class="center mt-8" style="font-family:var(--font-body);font-style:italic;font-size:15px;color:var(--text-muted);">Adicione produtos a esta coleção no admin — os quadros sem imagem mostram o fundo de linho até você subir as fotos.</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Coleção",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Sobrelinha", "default": "Sala · Primeiro drop 2026" },
    { "type": "text", "id": "fallback_title", "label": "Título (sem coleção)", "default": "Nada aqui existe só para preencher a prateleira." },
    { "type": "text", "id": "scene_line", "label": "Linha de cena (sem descrição da coleção)", "info": "A descrição da coleção no admin tem prioridade sobre este campo.", "default": "Onde o dia começa: a bolsa pronta ao lado da toalha, antes do primeiro saque." },
    { "type": "header", "content": "Banner da sala" },
    { "type": "checkbox", "id": "show_banner", "label": "Mostrar banner", "default": false },
    { "type": "image_picker", "id": "banner_image", "label": "Imagem do banner", "info": "Sem imagem escolhida, usa a foto de campanha embutida no tema (campo abaixo)." },
    { "type": "text", "id": "banner_asset", "label": "Arquivo embutido (assets)", "default": "photo-club-court.jpg" }
  ],
  "blocks": [
    {
      "type": "editorial",
      "name": "Foto editorial da banda",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Foto", "info": "Cada banda de 4 produtos ganha uma foto grande ao lado, alternando o lado. As fotos seguem a ordem dos blocos e repetem se houver mais bandas que fotos. Sem foto escolhida, usa a imagem de campanha embutida (campo abaixo)." },
        { "type": "text", "id": "asset", "label": "Arquivo embutido (assets)", "default": "photo-interlude-gravel.jpg" },
        { "type": "text", "id": "caption", "label": "Legenda", "default": "Entre um jogo e outro" }
      ]
    }
  ],
  "presets": [{
    "name": "Coleção",
    "blocks": [
      { "type": "editorial", "settings": { "asset": "photo-interlude-gravel.jpg", "caption": "Entre um jogo e outro" } },
      { "type": "editorial", "settings": { "asset": "photo-editorial-wall.jpg", "caption": "Do clube ao café" } },
      { "type": "editorial", "settings": { "asset": "photo-interlude-chair.jpg", "caption": "A cadeira do juiz · fim de tarde" } }
    ]
  }]
}
{% endschema %}

<section class="section section--hairline-top" data-screen-label="Coleção em destaque">
  <div class="wrap">
    <div class="grid-head" data-reveal>
      {%- if section.settings.drop_label != blank -%}
        <p class="mt-4" style="margin-top:0;"><span class="tag">{{ section.settings.drop_label }}</span></p>
      {%- endif -%}
      {%- if section.settings.eyebrow != blank -%}<p class="eyebrow eyebrow--muted eyebrow--center mt-5">{{ section.settings.eyebrow }}</p>{%- endif -%}
      <h2 class="title mt-4">{{ section.settings.heading }}</h2>
    </div>

    {%- assign coll = collections[section.settings.collection] -%}
    <div class="product-grid" data-reveal>
      {%- if coll != blank and coll.products_count > 0 -%}
        {%- for product in coll.products limit: section.settings.limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Onboarding fallback — identical demo tiles {%- endcomment -%}
        {% render 'product-card', ph_category: 'Bolsas', ph_name: 'A Diária', ph_price: 'R$ 590', ph_tag: 'Novo', ph_label: 'bolsa · foto de produto', ph_url: routes.all_products_collection_url %}
        {% render 'product-card', ph_category: 'Bolsas', ph_name: 'A de Duas Raquetes', ph_price: 'R$ 720', ph_label: 'bolsa · foto de produto', ph_url: routes.all_products_collection_url %}
        {% render 'product-card', ph_category: 'Grips', ph_name: 'O Grip', ph_price: 'R$ 79', ph_label: 'grip · foto de produto', ph_url: routes.all_products_collection_url %}
      {%- endif -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="center mt-7">
        <a href="{% if coll != blank %}{{ coll.url }}{% else %}{{ routes.all_products_collection_url }}{% endif %}" class="btn btn--outline">{{ section.settings.button_label }}</a>
        {%- if section.settings.note != blank -%}
          <p class="mt-5" style="font-family:var(--font-body);font-style:italic;font-size:15px;color:var(--text-muted);">{{ section.settings.note }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Coleção em destaque",
  "settings": [
    { "type": "text", "id": "drop_label", "label": "Etiqueta do drop", "info": "O ritmo do clube: numerar o drop, nunca gritar urgência.", "default": "Drop Nº 01 · Aberto" },
    { "type": "text", "id": "eyebrow", "label": "Sobrelinha", "info": "Coleções levam nome de sala do clube, não de categoria.", "default": "O Vestiário" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Cinco bolsas. Cada uma para uma forma de chegar à quadra." },
    { "type": "collection", "id": "collection", "label": "Coleção" },
    { "type": "range", "id": "limit", "min": 3, "max": 12, "step": 3, "label": "Quantos produtos", "default": 3 },
    { "type": "text", "id": "button_label", "label": "Botão", "default": "Ver a coleção" },
    { "type": "text", "id": "note", "label": "Nota sob o botão", "default": "Cada caixa do drop leva o número da série no cartão, escrito à mão." }
  ],
  "presets": [{ "name": "Coleção em destaque" }]
}
{% endschema %}

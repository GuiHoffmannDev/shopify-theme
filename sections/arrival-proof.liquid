<section class="section section--inverse" data-screen-label="Chegada">
  <div class="wrap">
    <div class="split">
      <div class="split__media arrival-media" data-reveal>
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}" loading="lazy">
        {%- elsif section.settings.asset != blank -%}
          <img src="{{ section.settings.asset | asset_url }}" alt="" width="928" height="1152" loading="lazy">
        {%- else -%}
          <div class="ph ph--inverse" style="height:520px;"><span>{{ section.settings.placeholder_label }}</span></div>
        {%- endif -%}
        {%- if section.settings.caption != blank -%}
          <p class="arrival-caption">{{ section.settings.caption }}</p>
        {%- endif -%}
      </div>
      <div data-reveal>
        {%- if section.settings.eyebrow != blank -%}<p class="eyebrow eyebrow--inverse" style="opacity:.7;">{{ section.settings.eyebrow }}</p>{%- endif -%}
        <h2 class="mt-4" style="font-family:var(--font-display);font-weight:var(--weight-display);font-size:36px;line-height:1.12;">{{ section.settings.heading }}</h2>
        <hr class="rule rule--left rule--inverse mt-5">
        <div class="mt-4" style="opacity:.85;line-height:1.6;">{{ section.settings.body }}</div>
        {%- if section.blocks.size > 0 -%}
          <ol class="arrival-steps">
            {%- for block in section.blocks -%}
              <li {{ block.shopify_attributes }}><span class="n">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>{{ block.settings.text }}</li>
            {%- endfor -%}
          </ol>
        {%- endif -%}
        {%- if section.settings.quote != blank -%}
          <figure class="arrival-quote">
            <blockquote><p>{{ section.settings.quote }}</p></blockquote>
            {%- if section.settings.quote_attr != blank -%}
              <figcaption>{{ section.settings.quote_attr }}</figcaption>
            {%- endif -%}
          </figure>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Prova de chegada",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Imagem", "info": "Sem imagem escolhida, usa a foto de campanha embutida no tema (campo abaixo)." },
    { "type": "text", "id": "asset", "label": "Arquivo embutido (assets)", "default": "photo-arrival-card.jpg" },
    { "type": "text", "id": "caption", "label": "Legenda da foto", "default": "A conferência antes da caixa fechar" },
    { "type": "text", "id": "placeholder_label", "label": "Legenda do placeholder", "default": "foto · unboxing com dust bag" },
    { "type": "text", "id": "eyebrow", "label": "Sobrelinha", "default": "Antes de chegar à sua porta" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Conferida, protegida e assinada por quem embalou." },
    { "type": "richtext", "id": "body", "label": "Texto", "default": "<p>Cada bolsa vai dentro de dust bag, com o grip acondicionado à parte e o cartão do primeiro drop. A caixa leva seu nome antes de levar nosso logo — e uma etiqueta de troca já impressa, caso você mude de ideia em 30 dias.</p>" },
    { "type": "header", "content": "Frase da casa" },
    { "type": "paragraph", "content": "A linha que fecha a seção. Deixe em branco para não mostrar." },
    { "type": "textarea", "id": "quote", "label": "Frase", "default": "A caixa leva seu nome antes de levar nosso logo." },
    { "type": "text", "id": "quote_attr", "label": "Atribuição", "default": "Controle de qualidade, assinado à mão" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Etapa do ritual",
      "settings": [
        { "type": "text", "id": "text", "label": "Texto", "default": "A bolsa entra na dust bag; o grip viaja à parte" }
      ]
    }
  ],
  "presets": [{
    "name": "Prova de chegada",
    "blocks": [
      { "type": "step", "settings": { "text": "A bolsa entra na dust bag; o grip viaja à parte" } },
      { "type": "step", "settings": { "text": "O cartão do drop leva o número da série e a assinatura de quem embalou" } },
      { "type": "step", "settings": { "text": "A etiqueta de troca já vai impressa — 30 dias, sem perguntas" } }
    ]
  }]
}
{% endschema %}

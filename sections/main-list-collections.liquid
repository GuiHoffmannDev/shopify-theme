<section class="section" data-screen-label="Lista de coleções">
  <div class="wrap">
    <div class="grid-head">
      <p class="eyebrow eyebrow--muted eyebrow--center">{{ section.settings.eyebrow }}</p>
      <h1 class="display-2 mt-4">{{ section.settings.heading }}</h1>
    </div>
    <div class="product-grid">
      {%- if collections.size > 0 -%}
        {%- for collection in collections -%}
          <a href="{{ collection.url }}" class="pcard">
            <div class="pcard__media">
              {%- if collection.featured_image -%}
                <img src="{{ collection.featured_image | image_url: width: 800 }}" alt="{{ collection.title | escape }}" loading="lazy">
              {%- else -%}
                <div class="pcard__linen"><span>sala · foto fora de contexto</span></div>
              {%- endif -%}
            </div>
            <div class="pcard__name" style="margin-top:16px;">{{ collection.title }}</div>
            <div class="pcard__price">{{ collection.products_count }} {{ 'general.items' | t }}</div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Onboarding — salas do clube (Regra #1) {%- endcomment -%}
        {% render 'product-card', ph_category: 'Bolsas', ph_name: 'O Vestiário', ph_price: '5 itens', ph_label: 'sala · foto fora de contexto', ph_url: routes.all_products_collection_url %}
        {% render 'product-card', ph_category: 'Grips e pequenos', ph_name: 'O Salão', ph_price: '3 itens', ph_label: 'sala · foto fora de contexto', ph_url: routes.all_products_collection_url %}
        {% render 'product-card', ph_category: 'Para presentear', ph_name: 'A Recepção', ph_price: 'Em breve', ph_label: 'sala · foto fora de contexto', ph_url: routes.all_products_collection_url %}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lista de coleções",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Sobrelinha", "info": "Nomeie as coleções como salas do clube: O Vestiário, O Salão, A Recepção — nunca como categoria de e-commerce.", "default": "As salas do clube" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Cada coisa guardada na sua sala." }
  ]
}
{% endschema %}
